    </g>
    <g>
      <rect x="74" y="74" width="106" height="42" rx="16" fill="currentColor"/>
      <line x1="86" y1="88" x2="156" y2="88" stroke="#fff" stroke-width="1.8" stroke-linecap="round" opacity="0.7"/>
