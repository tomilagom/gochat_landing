---

<section class="industries sec bg-paper has-blobs" id="solutions">
  <span class="blob blob-violet blob-lg blob-anim-a parallax" style="top: 8%; left: -180px;" aria-hidden="true"></span>
  <span class="blob blob-green-deep blob-md blob-anim-b" style="bottom: 5%; right: -120px;" aria-hidden="true"></span>
  <div class="wrap industries-head">
    <div>
      <span class="eyebrow">{copy.eyebrow}</span>
      <h2 class="h2 industries-title">
        {copy.titleLine1}<br/>
        <span class="ind-accent">{copy.titleAccent}</span>
      </h2>
    </div>
    <p class="lead industries-lead">{copy.lead}</p>
  </div>

  <div class="wrap industries-grid reveal-stagger" data-expandable-group>
    {items.map((it) => (
      <article class={`indi accent-${it.accent}`} data-expand tabindex="0" aria-expanded="false">
        <div class="indi-visual" set:html={VISUALS[it.visual]} />
        <span class="indi-tag">{it.tag} · {copy.useCase}</span>

        <div class="indi-summary">
          <header class="indi-h">
            <h3 class="indi-name">{it.name}</h3>
            <span class="indi-toggle" aria-hidden="true">
              <svg class="ic-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
              <svg class="ic-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/></svg>
            </span>
          </header>
          <p class="indi-tagline">{it.tagline}</p>
          <span class="indi-metric">{it.metric}</span>
        </div>

        <div class="indi-expand">
          <p class="indi-blurb">{it.blurb}</p>
          <ul class="indi-bullets">
            {it.bullets.map((b) => (
              <li><span class="tick" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="9" height="9" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l3.5 3.5L13 4"/></svg>
              </span>{b}</li>
            ))}
          </ul>
          <a class="indi-link" href={it.href}>
            <span>{copy.explore}</span>
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .industries-head {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 48px;
    align-items: end;
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .industries-title { max-width: 22ch; font-size: clamp(32px, 4vw, 56px); }
  .industries-lead { justify-self: end; max-width: 38ch; }
  .ind-accent { color: var(--gc-primary); }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }

  .indi {
    background: #fff;
    border: 1px solid var(--border-default);
    border-radius: var(--r-2xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-xs);
    position: relative;
    cursor: pointer;
    transition:
      box-shadow var(--dur-med) var(--ease-out-expo),
      border-color var(--dur-med) var(--ease-out-expo);
  }
  .indi:hover, .indi:focus-within, .indi.is-open {
    box-shadow: var(--shadow-md);
    border-color: var(--gc-primary-soft);
  }
  .indi:focus-visible { outline: none; box-shadow: var(--shadow-focus); }

  /* Accent palette mapping */
  .accent-green  { --ind-accent: var(--gc-accent-green-deep); --ind-bg: var(--gc-accent-green-mist); }
  .accent-violet { --ind-accent: var(--gc-primary-deep); --ind-bg: var(--gc-primary-mist); }
  .accent-coral  { --ind-accent: #8B2A45; --ind-bg: var(--gc-accent-coral-soft); }

  /* Visual area replaces the old image */
  .indi-visual {
    position: relative;
    height: 160px;
    background: var(--ind-bg);
    color: var(--ind-accent);
    display: grid;
    place-items: center;
    overflow: hidden;
  }
  .indi-visual :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .indi-tag {
    position: absolute; top: 14px; left: 14px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    color: var(--fg-2);
    padding: 6px 12px;
    border-radius: var(--r-full);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
    box-shadow: var(--shadow-xs);
    z-index: 2;
  }

  .indi-summary {
    padding: 24px 24px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .indi-h {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .indi-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    letter-spacing: var(--tr-tight);
    color: var(--fg-1);
    line-height: 1.05;
  }
  .indi-toggle {
    display: inline-grid;
    place-items: center;
    width: 32px; height: 32px;
    border-radius: var(--r-full);
    background: var(--gc-n-100);
    color: var(--fg-2);
    flex-shrink: 0;
    transition: background var(--dur-med) var(--ease-out-expo), color var(--dur-med) var(--ease-out-expo);
  }
  .indi-toggle svg { width: 14px; height: 14px; }
  .indi-toggle .ic-minus { display: none; }
  .indi:hover .indi-toggle,
  .indi.is-open .indi-toggle {
    background: var(--ind-accent);
    color: #fff;
  }
  .indi.is-open .indi-toggle .ic-plus { display: none; }
  .indi.is-open .indi-toggle .ic-minus { display: block; }

  .indi-tagline {
    color: var(--fg-2);
    font-size: 14px;
    line-height: 1.45;
  }
  .indi-metric {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    background: var(--ind-accent);
    color: #fff;
    padding: 6px 12px;
    border-radius: var(--r-full);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.01em;
    line-height: 1;
    margin-top: 4px;
  }

  /* Collapsed -> expanded */
  .indi-expand {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    padding: 0 24px;
    transition:
      max-height 0.45s var(--ease-out-expo),
      opacity 0.3s var(--ease-out-expo),
      padding 0.3s var(--ease-out-expo);
  }
  @media (hover: hover) and (pointer: fine) {
    .indi:hover .indi-expand { max-height: 520px; opacity: 1; padding: 0 24px 24px; }
  }
  .indi:focus-within .indi-expand,
  .indi.is-open .indi-expand {
    max-height: 520px;
    opacity: 1;
    padding: 0 24px 24px;
  }

  .indi-blurb {
    color: var(--fg-2);
    font-size: 14px;
    line-height: 1.5;
    border-top: 1px dashed var(--border-default);
    padding-top: 16px;
  }
  .indi-bullets {
    display: flex; flex-direction: column;
    gap: 8px;
    margin-top: 14px;
  }
  .indi-bullets li {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 13px;
    color: var(--fg-2);
    font-weight: 500;
  }
  .indi-bullets .tick {
    display: inline-grid; place-items: center;
    width: 18px; height: 18px;
    background: #fff;
    border: 1px solid var(--ind-accent);
    color: var(--ind-accent);
    border-radius: var(--r-full);
    flex-shrink: 0;
  }

  .indi-link {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 13px;
    color: var(--gc-primary);
    letter-spacing: 0.01em;
  }
  .indi-link svg { transition: transform var(--dur-med) var(--ease-out-expo); }
  .indi-link:hover svg { transform: translateX(4px); }

  @media (max-width: 980px) {
    .industries-head { grid-template-columns: 1fr; }
    .industries-lead { justify-self: start; }
    .industries-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .indi-name { font-size: 22px; }
    .industries-title { font-size: clamp(28px, 7.5vw, 40px); }
    .indi-visual { height: 130px; }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.industries-grid [data-expand]');
  cards.forEach((card) => {
    const toggle = (open?: boolean) => {
      const next = open ?? !card.classList.contains('is-open');
      card.classList.toggle('is-open', next);
      card.setAttribute('aria-expanded', String(next));
    };
    card.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('a')) return;
      toggle();
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const t = e.target as HTMLElement;
        if (t.closest('a')) return;
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
