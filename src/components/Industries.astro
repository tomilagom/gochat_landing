        ],
        metric: '3× más leads calificados',
        accent: 'green',
        visual: 'lead',
        href: localizedHref('/#demo', lang),
      },
      {
        tag: '02',
        name: 'Atención al cliente',
        tagline: 'Resuelve solo, escala con contexto.',
        blurb: 'El 80% de las conversaciones en piloto automático; el resto a un humano con todo el hilo cargado. Tu equipo deja de repetirse.',
        bullets: [
          'Agente de IA que responde 24/7 con tu tono',
          'Escalada inteligente con todo el contexto',
          'Multilingüe de fábrica',
          'Inbox unificado, tags e historial',
        ],
        metric: '< 2 min de primera respuesta',
        accent: 'violet',
        visual: 'support',
        href: localizedHref('/#demo', lang),
      },
      {
        tag: '03',
        name: 'Ventas y comercio',
        tagline: 'Del scroll al checkout en el chat.',
        blurb: 'Recupera carritos, recomienda productos y cierra órdenes sin que el cliente salga de la conversación.',
        bullets: [
          'Catálogos y carruseles en el chat',
          'Flujos de carrito abandonado y postventa',
          'Shopify, Tienda Nube, WooCommerce',
          'Pagos en chat y updates de envío',
        ],
        metric: '+30% conversión a venta',
        accent: 'coral',
        visual: 'sales',
        href: localizedHref('/ecommerce', lang),
      },
    ]
  : [
      {
        tag: '01',
        name: 'Lead generation',
        tagline: 'Capture intent everywhere.',
        blurb: 'Turn every comment, click and DM into a qualified contact. The bot asks, scores and lands leads in your CRM while they are still warm.',
        bullets: [
          'Auto-reply to comments and ads',
          'Conversational forms with zero friction',
          'Sync to HubSpot, Salesforce, Sheets',
          'Real-time hot-lead alerts',
        ],
        metric: '3× more qualified leads',
        accent: 'green',
        visual: 'lead',
        href: '/#demo',
      },
      {
        tag: '02',
        name: 'Customer support',
        tagline: 'Resolve solo, escalate with context.',
        blurb: 'The first 80% of conversations on autopilot; the rest to a human with the full thread loaded. Your team stops repeating itself.',
        bullets: [
          'AI agent answers 24/7 in your tone',
          'Smart escalation with full context',
          'Multilingual out of the box',
          'Unified inbox, tags and history',
        ],
        metric: '< 2 min first response',
        accent: 'violet',
        visual: 'support',
        href: '/#demo',
      },
      {
        tag: '03',
        name: 'Sales & commerce',
        tagline: 'From scroll to checkout in chat.',
        blurb: 'Recover carts, recommend products and close orders without the customer ever leaving the conversation.',
        bullets: [
          'Product catalogs and carousels in chat',
          'Cart-recovery and post-purchase flows',
          'Shopify, Tienda Nube, WooCommerce',
          'In-chat payments and shipping updates',
        ],
        metric: '+30% conversion to sale',
        accent: 'coral',
        visual: 'sales',
        href: '/ecommerce',
      },
    ];

