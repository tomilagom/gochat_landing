---
import type { Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const isES = lang === 'es';

const copy = isES
  ? {
      eyebrow: 'Resultados',
      titlePart1: 'Impulsa ventas',
      titleAnd: 'y',
      titlePart2: 'conversiones.',
      lead: 'Convierte más interacciones en ventas con conversaciones automatizadas y personalizadas. Supera los límites de la comunicación tradicional.',
      metaEyebrow: 'En vivo · este año',
      metaLabel: 'Mensajes enviados en 2024',
      tile1: 'Canales',
      tile2: 'Uptime',
      tile3: 'API / semana',
    }
  : {
      eyebrow: 'Outcomes',
      titlePart1: 'Boost sales',
      titleAnd: 'and',
      titlePart2: 'conversions.',
      lead: 'Turn more interactions into sales with automated, personalized conversations. Go beyond the limits of traditional communication.',
      metaEyebrow: 'Live · this year',
      metaLabel: 'Messages sent in 2024',
      tile1: 'Channels',
      tile2: 'Uptime',
      tile3: 'API / week',
    };

const benefits = isES
  ? [
      { title: 'Aumenta el engagement', blurb: 'Alcanza a tus clientes en segundos — no en días.' },
      { title: 'Reduce el churn', blurb: 'Mantente presente con recordatorios oportunos y contextuales.' },
      { title: 'Ahorra tiempo y recursos', blurb: 'Automatiza el 80% repetitivo y deja que los humanos manejen lo importante.' },
      { title: 'Conexiones en tiempo real', blurb: 'Una conversación que nunca duerme, en cada canal.' },
    ]
  : [
      { title: 'Increase engagement', blurb: 'Reach customers in seconds — not days.' },
      { title: 'Reduce churn', blurb: 'Stay top-of-mind with timely, contextual nudges.' },
      { title: 'Save time and resources', blurb: 'Automate the repetitive 80% so humans handle what matters.' },
      { title: 'Real-time connections', blurb: 'A conversation that never sleeps, on every channel.' },
    ];
---

<section class="boost sec">
  <div class="wrap boost-grid">
    <div class="boost-copy">
      <span class="eyebrow">{copy.eyebrow}</span>
      <h2 class="h2 boost-title">
        {copy.titlePart1} <span class="boost-and">{copy.titleAnd}</span> {copy.titlePart2}
      </h2>
      <p class="lead boost-lead">{copy.lead}</p>

      <ul class="boost-benefits">
        {benefits.map((b, i) => (
          <li>
            <span class="num">0{i+1}</span>
            <div>
              <h3 class="b-title">{b.title}</h3>
              <p class="b-blurb">{b.blurb}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <aside class="boost-meta">
      <div class="meta-card">
        <span class="meta-eyebrow">{copy.metaEyebrow}</span>
        <div class="meta-num">+100k</div>
        <div class="meta-lbl">{copy.metaLabel}</div>
        <div class="meta-spark" aria-hidden="true">
          <svg viewBox="0 0 200 60" preserveAspectRatio="none">
            <defs>
              <linearGradient id="sparkfill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#33998C" stop-opacity="0.30"/>
                <stop offset="100%" stop-color="#33998C" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0,50 L20,42 L40,46 L60,30 L80,34 L100,20 L120,24 L140,12 L160,16 L180,6 L200,10 L200,60 L0,60 Z"
                  fill="url(#sparkfill)"/>
            <path d="M0,50 L20,42 L40,46 L60,30 L80,34 L100,20 L120,24 L140,12 L160,16 L180,6 L200,10"
                  fill="none" stroke="#33998C" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
          </svg>
        </div>
      </div>

      <div class="meta-row">
        <div class="meta-tile">
          <div class="meta-num-sm">12</div>
          <div class="meta-lbl-sm">{copy.tile1}</div>
        </div>
        <div class="meta-tile">
          <div class="meta-num-sm">99.97%</div>
          <div class="meta-lbl-sm">{copy.tile2}</div>
        </div>
        <div class="meta-tile">
          <div class="meta-num-sm">+100k</div>
          <div class="meta-lbl-sm">{copy.tile3}</div>
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .boost {
    position: relative;
    background:
      radial-gradient(ellipse 900px 600px at 80% 40%, var(--gc-primary-soft), transparent 65%),
      radial-gradient(ellipse 1200px 700px at 20% 60%, var(--gc-primary-mist), transparent 70%),
      var(--gc-primary-haze);
    overflow: hidden;
  }
  /* Curved transitions in/out of the violet wash */
  .boost::before,
  .boost::after {
    content: '';
    position: absolute;
    left: -10%; right: -10%;
    height: clamp(36px, 5vw, 64px);
    background-color: #fff;
    pointer-events: none;
    z-index: 1;
  }
  .boost::before {
    top: -1px;
    border-radius: 0 0 50% 50% / 0 0 100% 100%;
  }
  .boost::after {
    bottom: -1px;
    border-radius: 50% 50% 0 0 / 100% 100% 0 0;
  }
  .boost-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }
  .boost-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(34px, 4.4vw, 56px);
    letter-spacing: var(--tr-tight);
    line-height: var(--lh-tight);
    margin-top: 16px;
    text-wrap: balance;
    color: var(--fg-1);
  }
  .boost-and { color: var(--gc-accent-green); font-style: italic; font-weight: 600; }
  .boost-lead { margin-top: 18px; max-width: 52ch; }

  .boost-benefits {
    margin-top: 36px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .boost-benefits li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: start;
  }
  .num {
    display: inline-grid;
    place-items: center;
    width: 32px; height: 32px;
    border-radius: 999px;
    background: var(--gc-accent-green-soft);
    color: var(--gc-accent-green-deep);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }
  .b-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: var(--tr-snug);
    color: var(--fg-1);
  }
  .b-blurb { font-size: 14px; color: var(--fg-2); margin-top: 4px; line-height: 1.45; }

  /* Right panel */
  .boost-meta { display: flex; flex-direction: column; gap: 16px; }
  .meta-card {
    background: #fff;
    border: 1px solid var(--border-default);
    border-radius: var(--r-xl);
    padding: 28px 28px 0;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .meta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .meta-eyebrow::before {
    content: '';
    width: 7px; height: 7px;
    border-radius: 999px;
    background: var(--gc-accent-green);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  .meta-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 5vw, 64px);
    letter-spacing: var(--tr-tight);
    color: var(--fg-1);
    margin-top: 12px;
    line-height: 1;
  }
  .meta-lbl { color: var(--fg-3); font-size: 14px; margin-top: 4px; }
  .meta-spark { margin-top: 12px; height: 60px; }
  .meta-spark svg { width: 100%; height: 100%; }

  .meta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .meta-tile {
    background: #fff;
    border: 1px solid var(--border-default);
    border-radius: var(--r-lg);
    padding: 18px;
    display: flex; flex-direction: column; gap: 4px;
    box-shadow: var(--shadow-xs);
  }
  .meta-num-sm {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    color: var(--fg-1);
    letter-spacing: var(--tr-snug);
    line-height: 1;
  }
  .meta-lbl-sm { font-size: 12px; color: var(--fg-3); font-weight: 500; }

  @media (max-width: 880px) {
    .boost-grid { grid-template-columns: 1fr; }
    .boost-benefits { grid-template-columns: 1fr; }
  }
  @media (max-width: 560px) {
    .boost-title { font-size: clamp(28px, 8vw, 40px); }
    .meta-card { padding: 22px 22px 0; }
    .meta-num { font-size: 44px; }
    .meta-row { grid-template-columns: 1fr 1fr; }
    .meta-tile:nth-child(3) { grid-column: 1 / -1; }
  }
</style>
