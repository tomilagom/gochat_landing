---

<section class="chcaps sec bg-paper has-blobs" id="channel-capabilities">
  <span class="blob blob-violet-mist blob-xl blob-anim-a parallax" style="top: -180px; right: -160px;" aria-hidden="true"></span>
  <span class="blob blob-green blob-md blob-anim-b" style="bottom: -120px; left: -120px; opacity: 0.28;" aria-hidden="true"></span>

  <div class="wrap chcaps-head">
    <span class="eyebrow">{copy.eyebrow}</span>
    <h2 class="h2 chcaps-title">{copy.title}</h2>
    <p class="lead chcaps-lead">{copy.lead}</p>
  </div>

  <div class="wrap chcaps-grid reveal-stagger">
    {channels.map((c) => (
      <article class="chc" style={`--accent:${c.color}`} data-expand tabindex="0" aria-expanded="false">
        <div class="chc-summary">
          <div class="chc-icon">
            {c.icon.type === 'img' ? (
              <img src={c.icon.src} alt={c.name} loading="lazy" decoding="async"/>
            ) : (
              <span class="chc-icon-svg" set:html={SVG_ICONS[c.icon.key as string]} />
            )}
          </div>
          <div class="chc-meta">
            <h3 class="chc-name">{c.name}</h3>
            <span class="chc-tag">{c.tagline}</span>
          </div>
          <span class="chc-toggle" aria-hidden="true">
            <svg class="ic-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
            <svg class="ic-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/></svg>
          </span>
        </div>

        <div class="chc-bestfor">
          <span class="chc-bestfor-label">{copy.bestFor}</span>
          <span class="chc-bestfor-value">{c.bestFor}</span>
        </div>

        <div class="chc-expand">
          <span class="chc-section-label">{copy.capabilities}</span>
          <ul class="chc-bullets">
            {c.bullets.map((b) => (
              <li><span class="tick" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l3.5 3.5L13 4"/></svg>
              </span>{b}</li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .chcaps-head, .chcaps-grid { position: relative; z-index: 2; }
  .chcaps-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: clamp(40px, 5vw, 56px);
  }
  .chcaps-title { max-width: 28ch; }
  .chcaps-lead { max-width: 50ch; }

  .chcaps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    align-items: start;
  }

  .chc {
    background: #fff;
    border: 1px solid var(--border-default);
    border-radius: var(--r-xl);
    padding: 22px 22px 18px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-xs);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition:
      box-shadow var(--dur-med) var(--ease-out-expo),
      border-color var(--dur-med) var(--ease-out-expo);
  }
  .chc::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-slow) var(--ease-out-expo);
  }
  .chc:hover, .chc:focus-within, .chc.is-open {
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }
  .chc:hover::after, .chc:focus-within::after, .chc.is-open::after { transform: scaleX(1); }
  .chc:focus-visible { outline: none; box-shadow: var(--shadow-focus); }

  .chc-summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
  }

  .chc-icon {
    width: 40px; height: 40px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--gc-primary-mist);
    background: color-mix(in srgb, var(--accent) 12%, #fff);
    color: var(--accent);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .chc-icon img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 12px;
  }
  .chc-icon-svg { display: grid; place-items: center; width: 100%; height: 100%; }
  .chc-icon-svg :global(svg) { width: 20px; height: 20px; }

  .chc-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: var(--tr-snug);
    color: var(--fg-1);
    line-height: 1.1;
  }
  .chc-tag {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-3);
    font-weight: 600;
    margin-top: 3px;
    display: inline-block;
  }

  .chc-toggle {
    display: inline-grid;
    place-items: center;
    width: 28px; height: 28px;
    border-radius: var(--r-full);
    background: var(--gc-n-100);
    color: var(--fg-2);
    flex-shrink: 0;
    transition: background var(--dur-med) var(--ease-out-expo), color var(--dur-med) var(--ease-out-expo);
  }
  .chc-toggle svg { width: 12px; height: 12px; }
  .chc-toggle .ic-minus { display: none; }
  .chc:hover .chc-toggle,
  .chc.is-open .chc-toggle {
    background: var(--accent);
    color: #fff;
  }
  .chc.is-open .chc-toggle .ic-plus { display: none; }
  .chc.is-open .chc-toggle .ic-minus { display: block; }

  .chc-bestfor {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 11px;
    background: var(--gc-primary-haze);
    background: color-mix(in srgb, var(--accent) 8%, #fff);
    border: 1px solid var(--border-default);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    border-radius: var(--r-full);
    align-self: flex-start;
    max-width: 100%;
  }
  .chc-bestfor-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--fg-3);
  }
  .chc-bestfor-value {
    font-size: 12.5px;
    font-weight: 700;
    color: var(--accent);
    filter: brightness(0.85);
  }

  /* Collapsed -> expanded */
  .chc-expand {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height 0.45s var(--ease-out-expo),
      opacity 0.3s var(--ease-out-expo),
      margin 0.3s var(--ease-out-expo);
  }
  @media (hover: hover) and (pointer: fine) {
    .chc:hover .chc-expand { max-height: 420px; opacity: 1; margin-top: 2px; }
  }
  .chc:focus-within .chc-expand,
  .chc.is-open .chc-expand {
    max-height: 420px;
    opacity: 1;
    margin-top: 2px;
  }

  .chc-section-label {
    display: block;
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--fg-3);
    padding-top: 14px;
    border-top: 1px dashed var(--border-default);
    margin-bottom: 12px;
  }

  .chc-bullets {
    display: flex; flex-direction: column;
    gap: 9px;
  }
  .chc-bullets li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13px;
    color: var(--fg-2);
    font-weight: 500;
    line-height: 1.45;
  }
  .chc-bullets .tick {
    display: inline-grid; place-items: center;
    width: 18px; height: 18px;
    background: var(--gc-primary-mist);
    background: color-mix(in srgb, var(--accent) 14%, #fff);
    color: var(--accent);
    border-radius: var(--r-full);
    flex-shrink: 0;
    margin-top: 1px;
    filter: brightness(0.92);
  }

  @media (max-width: 980px) {
    .chcaps-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .chcaps-grid { grid-template-columns: 1fr; }
    .chcaps-title { font-size: clamp(28px, 8vw, 40px); }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.chcaps-grid [data-expand]');
  cards.forEach((card) => {
    const toggle = (open?: boolean) => {
      const next = open ?? !card.classList.contains('is-open');
      card.classList.toggle('is-open', next);
      card.setAttribute('aria-expanded', String(next));
    };
    card.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (t.closest('a')) return;
      toggle();
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const t = e.target as HTMLElement;
        if (t.closest('a')) return;
        e.preventDefault();
        toggle();
      }
    });
  });
</script>
