---
import { localizedHref, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const isES = lang === 'es';

const copy = isES
  ? {
      tagline: 'Aumenta tus ingresos, reduce los costos operativos y enamora a tus clientes.',
      navAria: 'Navegación del pie de página',
      certsAria: 'Certificaciones',
      copyrightTail: 'Un producto de',
      appStore: 'Descarga en la App Store',
      googlePlay: 'Disponible en Google Play',
      col1: 'Producto',
      col2: 'Soluciones',
      col3: 'Comparar',
      col4: 'Legal',
      home: 'Inicio',
      pricing: 'Precios',
      docs: 'Docs',
      demo: 'Solicitar demo',
      automotive: 'Automotive',
      realEstate: 'Real estate',
      ecommerce: 'E-commerce',
      altManychat: 'Alternativa a Manychat',
      altBotmaker: 'Alternativa a Botmaker',
      privacy: 'Política de Privacidad',
      terms: 'Términos y condiciones',
    }
  : {
      tagline: 'Increase your revenue, reduce operation costs & delight your customers.',
      navAria: 'Footer navigation',
      certsAria: 'Certifications',
      copyrightTail: 'A product by',
      appStore: 'Download on the App Store',
      googlePlay: 'Get it on Google Play',
      col1: 'Product',
      col2: 'Solutions',
      col3: 'Compare',
      col4: 'Legal',
      home: 'Home',
      pricing: 'Pricing',
      docs: 'Docs',
      demo: 'Book a demo',
      automotive: 'Automotive',
      realEstate: 'Real estate',
      ecommerce: 'E-commerce',
      altManychat: 'Alternative to Manychat',
      altBotmaker: 'Alternative to Botmaker',
      privacy: 'Privacy Policy',
      terms: 'Terms & conditions',
    };

const topHref = '#top';
const pricingHref = isES ? '/es/#pricing' : '#pricing';
const demoHref = isES ? '/es/#demo' : '#demo';

const cols = [
  {
    title: copy.col1,
    items: [
      { label: copy.home, href: topHref },
      { label: copy.pricing, href: pricingHref },
      { label: copy.docs, href: 'https://docs.gochat.ar' },
      { label: copy.demo, href: demoHref },
    ],
  },
  {
    title: copy.col2,
    items: [
      { label: copy.automotive, href: localizedHref('/automotive', lang) },
      { label: copy.realEstate, href: localizedHref('/real-estate', lang) },
      { label: copy.ecommerce, href: localizedHref('/ecommerce', lang) },
    ],
  },
  {
    title: copy.col3,
    items: [
      { label: copy.altManychat, href: localizedHref('/alternative-to-manychat', lang) },
      { label: copy.altBotmaker, href: localizedHref('/alternative-to-botmaker', lang) },
      { label: 'llms.txt', href: '/llms.txt' },
    ],
  },
  {
    title: copy.col4,
    items: [
      { label: copy.privacy, href: 'https://hyppo.io/privacy/' },
      { label: copy.terms, href: 'https://hyppo.io/terms-and-conditions/' },
    ],
  },
];
---

<footer class="foot">
  <div class="wrap foot-grid">
    <!-- LEFT: brand + visual elements -->
    <div class="foot-brand">
      <a href={topHref} class="foot-brand-logo" aria-label="GoChat">
        <img src="/media/gochat_logo-1-300x134.png" alt="GoChat"/>
      </a>
      <p class="foot-tagline">{copy.tagline}</p>

      <div class="foot-locales">
        <div class="locale">
          <span class="locale-flag" aria-hidden="true">🇪🇸</span>
          <div>
            <div class="locale-city">Barcelona</div>
            <a class="locale-mail" href="mailto:hello@gochat.ar">hello@gochat.ar</a>
          </div>
        </div>
        <div class="locale">
          <span class="locale-flag" aria-hidden="true">🇦🇷</span>
          <div>
            <div class="locale-city">Buenos Aires</div>
            <a class="locale-mail" href="mailto:hello@gochat.ar">hello@gochat.ar</a>
          </div>
        </div>
      </div>

