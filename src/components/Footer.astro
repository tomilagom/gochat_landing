<style>
  .foot {
    background: var(--gc-primary-soft);
    color: var(--gc-n-800);
    padding-block: clamp(64px, 7vw, 96px) 28px;
  }
  .foot a {
    color: var(--gc-n-800);
    transition: color var(--dur-fast) var(--ease-out-expo);
  }
  .foot a:hover { color: var(--gc-primary-deep); }

  /* ---- main grid: LEFT brand / RIGHT links ---- */
  .foot-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.6fr);
    gap: clamp(40px, 6vw, 96px);
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(46, 58, 143, 0.18);
  }

  .foot-brand {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  /* ---- logo ---- */
  .foot-brand-logo {
    display: inline-flex;
    align-items: center;
    height: 64px;
    width: fit-content;
  }
  .foot-brand-logo img {
    height: 64px !important;
    width: auto;
    display: block;
  }

  /* ---- tagline ---- */
  .foot-tagline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: var(--tr-snug);
    line-height: 1.4;
    color: var(--gc-primary-deep);
    max-width: 36ch;
    margin: 0;
  }

  /* ---- locales (plain, no card) ---- */
  .foot-locales {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  .locale {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .locale-flag {
    font-size: 20px;
    line-height: 1;
    margin-top: 2px;
  }
  .locale-city {
    color: var(--gc-primary-deep);
    font-weight: 700;
    font-size: 14px;
    font-family: var(--font-display);
    letter-spacing: var(--tr-snug);
  }
  .locale-mail {
    font-size: 13px;
    color: var(--gc-n-700) !important;
  }
  .locale-mail:hover { text-decoration: underline; text-underline-offset: 3px; }

  /* ---- app badges (horizontal, black like UChat) ---- */
  .foot-apps {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }
  .app-badge {
    display: inline-block;
    transition: transform var(--dur-med) var(--ease-out-expo), box-shadow var(--dur-med) var(--ease-out-expo);
    border-radius: 6px;
  }
  .app-badge:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }
  .app-badge svg { display: block; border-radius: 6px; }

  /* ---- certifications (horizontal row in bottom-right) ---- */
  .foot-certs {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .foot-certs img {
    max-height: 64px;
    width: auto;
    object-fit: contain;
  }
  .foot-certs .cert-meta { max-height: 32px; }

  /* ---- social ---- */
  .foot-social {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .social-link {
    display: inline-grid;
    place-items: center;
    width: 36px; height: 36px;
    border-radius: 999px;
    background: var(--gc-n-950);
    color: #fff !important;
    transition: transform var(--dur-fast) var(--ease-out-expo), background var(--dur-fast) var(--ease-out-expo);
  }
  .social-link svg { width: 16px; height: 16px; }
  .social-link:hover { transform: translateY(-2px); }
  .social-linkedin { background: #0A66C2; }
  .social-linkedin:hover { background: #004182; }

  /* ---- right side: link columns ---- */
  .foot-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(20px, 2.5vw, 40px);
  }
  .foot-col-title {
    display: block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--gc-primary-deep);
    margin-bottom: 18px;
    letter-spacing: var(--tr-snug);
  }
  .foot-col ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .foot-link {
    font-size: 14px;
    color: var(--gc-n-800);
    position: relative;
    display: inline-block;
  }
  .foot-link::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    bottom: -2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.35s var(--ease-out-expo);
  }
  .foot-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ---- bottom ---- */
  .foot-bottom {
    padding-top: 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
