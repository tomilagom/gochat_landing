          ['Resumen de conversación',    '✓', '✓', '✓'],
        ],
      },
      {
        id: 'flows',
        title: 'Flujos y sub-flujos',
        blurb: 'Diseño de conversaciones drag-and-drop.',
        rows: [
          ['Derivación a chat en vivo',  '✓', '✓', '✓'],
          ['Flujos ilimitados',          '✓', '✓', '✓'],
          ['Plantillas de WhatsApp',     '✓', '✓', '✓'],
          ['Plantillas de email',        '✓', '✓', '✓'],
          ['Esperas inteligentes',       '✓', '✓', '✓'],
        ],
      },
      {
        id: 'autom',
        title: 'Automatizaciones y herramientas',
        blurb: 'Triggers, secuencias y envíos masivos.',
        rows: [
          ['Detección de palabras clave',  '✓', '✓', '✓'],
          ['Secuencias',                   '✓', '✓', '✓'],
          ['Triggers condicionales',       '✓', '✓', '✓'],
          ['Palabras clave en comentarios','✓', '✓', '✓'],
          ['Facebook Lead Forms',          '✓', '✓', '✓'],
          ['Webhooks',                     '✓', '✓', '✓'],
          ['Envíos masivos',               '✓', '✓', '✓'],
