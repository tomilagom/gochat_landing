        ],
      },
      {
        id: 'channels',
        title: 'Channels',
        blurb: 'Every messaging surface, in one inbox.',
        rows: [
          ['Omnichannel inbox',       '✓', '✓', '✓'],
          ['WhatsApp Business API',   '✓', '✓', '✓'],
          ['Facebook + Instagram',    '✓', '✓', '✓'],
          ['Telegram',                '✓', '✓', '✓'],
          ['SMS',                     '✓', '✓', '✓'],
        ],
      },
      {
        id: 'ai',
        title: 'AI features',
        blurb: 'Agents, functions and MCP. You bring the model.',
        rows: [
          ['Autonomous agents',       '✓', '✓', '✓'],
          ['AI functions',            '✓', '✓', '✓'],
          ['MCP servers',             '✓', '✓', '✓'],
          ['Intention detection',     '✓', '✓', '✓'],
