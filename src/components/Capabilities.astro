---
import type { Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const isES = lang === 'es';

const copy = isES
  ? {
      eyebrow: 'Capacidades',
      title: 'Todo lo que necesitas, sin lo que sobra.',
    }
  : {
      eyebrow: 'Capabilities',
      title: 'Everything you need, in one place.',
    };

const caps = isES
  ? [
      {
        key: 'Outreach',
        title: 'Alcance',
        blurb: 'Messenger, Instagram, WhatsApp y llamadas. Donde esté tu cliente, ahí está GoChat.',
        span: 2,
        accent: 'green',
      },
      {
        key: 'AI features',
        title: 'Funcionalidades de IA',
        blurb: 'Agentes autónomos, tareas, servidores MCP y detección de intención. Tú eliges qué modelo correr.',
        span: 2,
        accent: 'violet',
      },
      {
        key: 'Easy setup',
        title: 'Configuración simple',
        blurb: 'Arrastra, suelta, publica. Sin código para tener un bot en vivo.',
        span: 2,
        accent: 'amber',
      },
      {
        key: 'Lead generation',
        title: 'Generación de leads',
        blurb: 'Captura y califica contactos automáticamente, sin pedir un formulario.',
        span: 2,
        accent: 'green',
      },
      {
        key: 'Integrations',
        title: 'Integraciones',
        blurb: 'Conecta tus herramientas favoritas: CRMs, pagos, calendarios, hojas de cálculo.',
        span: 2,
        accent: 'violet',
      },
      {
        key: 'Human takeover',
        title: 'Derivación a humano',
        blurb: 'Pasa la conversación a un agente humano con todo el contexto ya cargado.',
        span: 2,
        accent: 'coral',
      },
    ]
  : [
      {
        key: 'Outreach',
        title: 'Outreach',
        blurb: 'Messenger, Instagram, WhatsApp, calls. Wherever your customers chat, you show up.',
        span: 2,
        accent: 'green',
      },
      {
        key: 'AI features',
        title: 'AI features',
        blurb: 'Autonomous agents, tasks, MCP servers and intention detection. You pick the model.',
        span: 2,
        accent: 'violet',
      },
      {
        key: 'Easy setup',
        title: 'Easy setup',
        blurb: 'Drag, drop, ship. No coding required to get a bot live.',
        span: 2,
        accent: 'amber',
      },
      {
        key: 'Lead generation',
        title: 'Lead generation',
        blurb: 'Capture and qualify contacts automatically, with no form to fill in.',
        span: 2,
        accent: 'green',
      },
      {
        key: 'Integrations',
        title: 'Integrations',
        blurb: 'Connect your favorite tools: CRMs, payments, calendars, sheets.',
        span: 2,
        accent: 'violet',
      },
      {
        key: 'Human takeover',
        title: 'Human takeover',
        blurb: 'Hand the chat to a human agent with the full thread already in front of them.',
        span: 2,
        accent: 'coral',
      },
    ];

const ICONS = {
  Outreach: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11a8 8 0 0 1 8-8h2a8 8 0 0 1 8 8v2a8 8 0 0 1-8 8H7l-4 3v-3a8 8 0 0 1 0-10Z"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>',
  'AI features': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><path d="M8 8h2v8H8zM14 8h2v8h-2zM8 12h8"/></svg>',
  'Easy setup': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3H9a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5 1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8V9a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1Z"/></svg>',
  'Lead generation': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  Integrations: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="9" width="6" height="6" rx="1"/><rect x="16" y="9" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><rect x="9" y="16" width="6" height="6" rx="1"/><path d="M8 12h2M14 12h2M12 8v2M12 14v2"/></svg>',
  'Human takeover': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="m22 11-3 3-3-3M19 4v10"/></svg>',
};
---

<section class="caps sec bg-paper has-blobs">
  <span class="blob blob-violet blob-lg blob-anim-a parallax" style="top: -120px; right: -120px;" aria-hidden="true"></span>
  <span class="blob blob-green blob-md blob-anim-b" style="bottom: -100px; left: 10%; opacity: 0.32;" aria-hidden="true"></span>
  <div class="wrap caps-head">
    <span class="eyebrow">{copy.eyebrow}</span>
    <h2 class="h2 caps-title">{copy.title}</h2>
  </div>

  <div class="wrap caps-grid reveal-stagger">
    {caps.map((c) => (
      <article class={`cap accent-${c.accent}`}>
        <div class="cap-icon" set:html={ICONS[c.key as keyof typeof ICONS]} />
        <div class="cap-body">
          <h3 class="cap-title">{c.title}</h3>
          <p class="cap-blurb">{c.blurb}</p>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .caps-head, .caps-grid { position: relative; z-index: 2; }
  .caps-head { display: flex; flex-direction: column; gap: 14px; margin-bottom: clamp(40px, 5vw, 56px); }
  .caps-title { max-width: 22ch; }

  .caps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .cap {
    background: #fff;
    border: 1px solid var(--border-default);
    border-radius: var(--r-xl);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    box-shadow: var(--shadow-xs);
    transition: box-shadow var(--dur-med) var(--ease-out-expo), transform var(--dur-med) var(--ease-out-expo);
  }
  .cap:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .cap-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: grid; place-items: center;
  }
  .cap-icon :global(svg) { width: 22px; height: 22px; }

  .accent-violet .cap-icon { background: var(--gc-primary-mist); color: var(--gc-primary-deep); }
  .accent-green  .cap-icon { background: var(--gc-accent-green-mist); color: var(--gc-accent-green-deep); }
  .accent-amber  .cap-icon { background: var(--gc-accent-amber-soft); color: #8C5A18; }
  .accent-coral  .cap-icon { background: var(--gc-accent-coral-soft); color: #8B2A45; }

  .cap-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: var(--tr-snug);
    color: var(--fg-1);
  }
  .cap-blurb { color: var(--fg-2); font-size: 14.5px; line-height: 1.5; }

  @media (max-width: 880px) {
    .caps-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .caps-grid { grid-template-columns: 1fr; }
    .caps-title { font-size: clamp(28px, 8vw, 40px); }
    .cap { padding: 22px; }
    .cap-title { font-size: 18px; }
  }
</style>
