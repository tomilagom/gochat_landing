---
import type { Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const isES = lang === 'es';

const copy = isES
  ? {
      seePricing: 'Ver precios',
      titlePart1: 'El',
      titleHighlight: 'Chatbot de IA',
      titlePart2: 'para cualquier negocio',
      lead: 'Construye flujos de automatización en minutos sobre 12+ canales sociales. Aumenta tus ingresos, reduce los costos operativos y enamora a tus clientes.',
      cta: 'Solicitar demo',
      trust1: 'Constructor sin código y de bajo código',
      trust2: 'Prueba gratis de 14 días',
      trust3: 'Sin tarjeta de crédito',
      anyChannel: 'CUALQUIER CANAL',
      anyModel: 'CUALQUIER MODELO',
      previewAria: 'Vista previa de conversación en vivo',
      mbpAlt: 'Meta Business Partner',
      chatName: 'Entrante · WhatsApp',
      chatSub: 'Agente de IA respondiendo',
      online: 'En línea',
      moreAria: 'Más opciones',
      msg1: '¡Hola! 👋 Necesito agendar un service para mi Camry.',
      msg1Meta: 'Bea · 10:42',
      msg2: '¡Hola Bea! Con gusto te ayudo. ¿Qué día te queda mejor?',
      msg2Meta: 'GoChat · gpt-4o',
      msg3: 'Jueves a la mañana, si es posible.',
      msg3Meta: 'Bea · 10:43',
      msg4Strong: 'Turno de 09:30 confirmado.',
      msg4Tools: ['CRM', 'SMS', 'Calendario'],
      typingAria: 'Escribiendo',
      pricingHref: '/es/#pricing',
      demoHref: '/es/#demo',
    }
  : {
      seePricing: 'See pricing',
      titlePart1: 'The',
      titleHighlight: 'AI Chatbot',
      titlePart2: 'for any business',
      lead: 'Build automation flows in minutes over 12+ social channels. Increase your revenue, reduce operation costs & delight your customers.',
      cta: 'Book a demo',
      trust1: 'No-code & low-code builder',
      trust2: '14-day free trial',
      trust3: 'No credit card required',
      anyChannel: 'ANY CHANNEL',
      anyModel: 'ANY MODEL',
      previewAria: 'Live conversation preview',
      mbpAlt: 'Meta Business Partner',
      chatName: 'Inbound · WhatsApp',
      chatSub: 'AI agent responding',
      online: 'Online',
      moreAria: 'More options',
      msg1: 'Hi! 👋 I need to schedule a service for my Camry.',
      msg1Meta: 'Bea · 10:42',
      msg2: 'Hi Bea! Happy to help. Which day works best for you?',
      msg2Meta: 'GoChat · gpt-4o',
      msg3: 'Thursday morning, if possible.',
      msg3Meta: 'Bea · 10:43',
      msg4Strong: '09:30 slot confirmed.',
      msg4Tools: ['CRM', 'SMS', 'Calendar'],
      typingAria: 'Typing',
      pricingHref: '/#pricing',
      demoHref: '/#demo',
    };

const SI = (slug: string) => `https://cdn.jsdelivr.net/npm/simple-icons@v14/icons/${slug}.svg`;

const channels = [
  { name: 'WhatsApp',  img: '/media/whatsapp-channel.png',                     brand: '#25D366', square: true },
  { name: 'Instagram', img: '/media/instagram-channel.png',                    brand: '#DD2A7B', square: true },
  { name: 'Webchat',   img: '/media/webchat-channel.png',                      brand: '#596AD5', square: true },
  { name: 'TikTok',    img: '/media/tiktok-scaled-e1763115488777-294x300.png', brand: '#0C0D14', square: true },
];
const models = [
  { name: 'ChatGPT',  img: '/media/chatgpt-icon.png',       brand: '#10A37F', square: true },
  { name: 'Gemini',   img: SI('googlegemini'),              brand: '#4285F4', remote: true },
  { name: 'DeepSeek', img: '/media/DeepSeek_logo_icon.png', brand: '#4D6BFE', square: true },
  { name: 'Meta',     img: SI('meta'),                      brand: '#0866FF', remote: true },
];
---

<section class="hero">
  <div class="wrap">
    <div class="hero-card">
      <img src="/media/meta-business-partner.png" alt={copy.mbpAlt} class="hero-mbp"/>

      <div class="hero-grid">
        <div class="hero-copy">
          <a class="see-pricing" href={copy.pricingHref}>{copy.seePricing} <span aria-hidden="true">→</span></a>

          <h1 class="hero-title">
            {copy.titlePart1} <span class="hl-pill">{copy.titleHighlight}</span> {copy.titlePart2}
          </h1>

          <p class="hero-lead">{copy.lead}</p>

          <a class="btn btn-primary btn-lg hero-cta" href={copy.demoHref}>{copy.cta}</a>

          <ul class="hero-trust">
            <li><span class="check" aria-hidden="true">✓</span> {copy.trust1}</li>
            <li><span class="check" aria-hidden="true">✓</span> {copy.trust2}</li>
            <li><span class="check" aria-hidden="true">✓</span> {copy.trust3}</li>
          </ul>

          <div class="any-pill any-pill--channel">
            <span class="any-label">{copy.anyChannel}</span>
            <ul class="any-icons">
              {channels.map((c) => (
                <li title={c.name} style={`--brand:${c.brand}`}>
                  <img src={c.img} alt={c.name}/>
                </li>
              ))}
            </ul>
          </div>

          <div class="any-pill any-pill--model">
            <span class="any-label">{copy.anyModel}</span>
            <ul class="any-icons">
              {models.map((m) => (
                <li title={m.name} style={`--brand:${m.brand}; --mask:url(${m.img})`}>
                  {m.remote ? (
                    <span class="ico-mask" aria-label={m.name}></span>
                  ) : (
                    <img src={m.img} alt={m.name}/>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <aside class="hero-stage" aria-label={copy.previewAria}>
          <div class="chat-glow" aria-hidden="true"></div>

          <div class="chat-frame">
            <header class="chat-bar">
              <div class="chat-id">
                <div class="chat-avatar">
                  <span class="chat-avatar-circ">B</span>
                  <span class="chat-avatar-badge" aria-hidden="true">
                    <img src="/media/whatsapp-channel.png" alt="" width="12" height="12"/>
                  </span>
                </div>
                <div>
                  <div class="chat-name">{copy.chatName}</div>
                  <div class="chat-sub">{copy.chatSub}</div>
                </div>
              </div>
              <div class="chat-actions">
                <span class="pill pill-green pill-sm"><span class="dot"></span>{copy.online}</span>
                <button class="chat-icon-btn" aria-label={copy.moreAria} type="button">
                  <svg viewBox="0 0 20 20" width="14" height="14" aria-hidden="true">
                    <circle cx="4" cy="10" r="1.6" fill="currentColor"/>
                    <circle cx="10" cy="10" r="1.6" fill="currentColor"/>
                    <circle cx="16" cy="10" r="1.6" fill="currentColor"/>
                  </svg>
                </button>
              </div>
            </header>

            <div class="chat-body">
              <div class="msg recv" style="animation-delay:.1s">
                <span class="msg-avatar" aria-hidden="true">B</span>
                <div class="msg-col">
                  <span class="bubble">{copy.msg1}</span>
                  <span class="meta">{copy.msg1Meta}</span>
                </div>
              </div>

              <div class="msg sent" style="animation-delay:.5s">
                <div class="msg-col">
                  <span class="bubble sent">{copy.msg2}</span>
                  <span class="meta">
                    {copy.msg2Meta}
                    <svg class="meta-checks" viewBox="0 0 16 10" aria-hidden="true">
                      <path d="M1 5l2.5 2.5L8 2" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                      <path d="M5 5l2.5 2.5L12 2" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </div>

              <div class="msg recv" style="animation-delay:1.1s">
                <span class="msg-avatar" aria-hidden="true">B</span>
                <div class="msg-col">
                  <span class="bubble">{copy.msg3}</span>
                  <span class="meta">{copy.msg3Meta}</span>
                </div>
              </div>

              <div class="msg sent" style="animation-delay:1.7s">
                <div class="msg-col">
                  <article class="action-card">
                    <div class="action-head">
                      <span class="action-check" aria-hidden="true">
                        <svg viewBox="0 0 18 18">
                          <path d="M5 9.2l2.6 2.6L13 6.4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                      <span class="action-strong">{copy.msg4Strong}</span>
                    </div>
                    <div class="action-tools">
                      {(copy.msg4Tools as string[]).map((t, i) => (
                        <span class={`tool-chip tool-chip-${i}`}>
                          {i === 0 && (
                            <svg viewBox="0 0 14 14" aria-hidden="true">
                              <circle cx="7" cy="5" r="2.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
                              <path d="M2 12c0-2.2 2.2-3.2 5-3.2s5 1 5 3.2" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linecap="round"/>
                            </svg>
                          )}
                          {i === 1 && (
                            <svg viewBox="0 0 14 14" aria-hidden="true">
                              <path d="M2 4a2 2 0 012-2h6a2 2 0 012 2v4a2 2 0 01-2 2H6.5L4 12V10a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.3" fill="none" stroke-linejoin="round"/>
                            </svg>
                          )}
                          {i === 2 && (
                            <svg viewBox="0 0 14 14" aria-hidden="true">
                              <rect x="2" y="3.2" width="10" height="9" rx="1.4" stroke="currentColor" stroke-width="1.3" fill="none"/>
                              <path d="M2 6h10M5 2v2.4M9 2v2.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                            </svg>
                          )}
                          {t}
                          <svg class="tool-chip-ok" viewBox="0 0 10 10" aria-hidden="true">
                            <path d="M1.5 5l2 2L8 2.5" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </span>
                      ))}
                    </div>
                  </article>
                </div>
              </div>

              <div class="msg recv typing" style="animation-delay:2.3s">
                <span class="msg-avatar" aria-hidden="true">B</span>
                <span class="bubble typing-bubble" aria-label={copy.typingAria}>
                  <span></span><span></span><span></span>
                </span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(20px, 3vw, 40px);
    padding-bottom: clamp(40px, 6vw, 80px);
    background: linear-gradient(180deg, var(--gc-primary-mist), var(--gc-primary-haze) 60%, #fff);
  }

  .hero-card {
    position: relative;
    border-radius: var(--r-2xl);
    padding: clamp(28px, 4vw, 64px) clamp(24px, 4vw, 56px);
    overflow: hidden;
    z-index: 0;
    isolation: isolate;
  }
  .hero-card::before {
    content: '';
    position: absolute;
    z-index: -2;
    left: -50%;
    top: -50%;
    width: 200%;
    height: 200%;
    background-repeat: no-repeat;
    background-position: 0 0;
    background-image: conic-gradient(
      transparent,
      transparent,
      transparent,
      var(--gc-primary)
    );
    animation: rotar-borde 7s linear infinite;
  }
  .hero-card::after {
    content: '';
    position: absolute;
    z-index: -1;
    inset: 2px;
    background: linear-gradient(180deg, var(--gc-primary-mist), var(--gc-primary-haze) 60%, #fff);
    border-radius: calc(var(--r-2xl) - 2px);
  }
  @keyframes rotar-borde {
    to { transform: rotate(1turn); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-card::before { animation: none; }
  }
  .hero-mbp {
    position: absolute;
    top: clamp(20px, 2vw, 28px);
    right: clamp(20px, 3vw, 32px);
    height: clamp(22px, 2vw, 30px);
    width: auto;
    object-fit: contain;
    z-index: 3;
    opacity: 0.85;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }

  /* "See pricing →" pill */
  .see-pricing {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(89, 106, 213, 0.18);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: var(--gc-primary-deep);
    width: fit-content;
    transition: background var(--dur-fast) var(--ease-out-expo);
  }
  .see-pricing:hover { background: #fff; }

  .hero-title {
    margin-top: 22px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.8vw, 56px);
    line-height: 1.08;
    letter-spacing: var(--tr-tight);
    color: var(--fg-1);
    text-wrap: balance;
  }
  .hl-pill {
    display: inline-block;
    padding: 0.04em 0.32em 0.06em;
    background: var(--gc-primary-soft);
    color: var(--gc-primary-deep);
    border-radius: 14px;
    margin: 0 0.06em;
  }

  .hero-lead {
    margin-top: 20px;
    font-size: clamp(16px, 1.3vw, 18px);
    color: var(--fg-2);
    line-height: 1.45;
    max-width: 56ch;
  }

  .hero-cta {
    margin-top: 24px;
    width: 100%;
    max-width: 460px;
    justify-content: center;
    padding-block: 16px;
    font-size: 15px;
  }

  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 16px 22px;
    margin-top: 18px;
    font-size: 13px;
    color: var(--fg-2);
  }
  .hero-trust li { display: inline-flex; align-items: center; gap: 8px; font-weight: 500; }
  .hero-trust .check {
    display: inline-grid; place-items: center;
    width: 18px; height: 18px;
    background: var(--gc-accent-green-soft);
    color: var(--gc-accent-green-deep);
    border-radius: 999px;
    font-size: 10px;
    font-weight: 800;
  }

  /* ANY CHANNEL / ANY MODEL pill bars */
  .any-pill {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--border-default);
    border-radius: 14px;
    width: fit-content;
    max-width: 100%;
  }
  .any-label {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--fg-3);
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .any-icons { display: inline-flex; gap: 8px; align-items: center; }
  .any-icons li {
    display: grid; place-items: center;
    width: 30px; height: 30px;
    border-radius: 8px;
    overflow: hidden;
    background: transparent;
  }
  .any-icons li img {
    width: 26px; height: 26px;
    object-fit: contain;
    display: block;
    border-radius: 6px;
  }
  .any-icons li .ico-mask {
    display: block;
    width: 22px; height: 22px;
    background-color: var(--brand);
    -webkit-mask: var(--mask) no-repeat center / contain;
            mask: var(--mask) no-repeat center / contain;
  }

  /* Right stage — chat frame */
  .hero-stage {
    position: relative;
    isolation: isolate;
    /* Reserve space so the Meta badge in the top-right of the hero card
       doesn't visually collide with the chat-frame top */
    padding-top: clamp(20px, 3vw, 32px);
  }

  /* Soft violet glow behind the frame */
  .chat-glow {
    position: absolute;
    inset: 20px 0 -20px 0;
    z-index: -1;
    background: radial-gradient(60% 50% at 50% 50%, rgba(89, 106, 213, 0.28) 0%, rgba(89, 106, 213, 0) 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .chat-frame {
    position: relative;
    background: linear-gradient(180deg, #ffffff 0%, #fbfaff 100%);
    border-radius: var(--r-2xl);
    border: 1px solid rgba(89, 106, 213, 0.14);
    box-shadow:
      0 24px 50px -16px rgba(46, 58, 143, 0.22),
      0 6px 16px -8px rgba(30, 25, 55, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    padding: 18px;
  }

  .chat-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 4px 4px 14px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .chat-id { display: flex; gap: 12px; align-items: center; min-width: 0; }
  .chat-name {
    font-weight: 700;
    font-size: 14px;
    color: var(--fg-1);
    letter-spacing: var(--tr-snug);
  }
  .chat-sub { font-size: 12px; color: var(--fg-3); }

  /* Chat avatar with channel badge overlay */
  .chat-avatar {
    position: relative;
    width: 42px;
    height: 42px;
    flex-shrink: 0;
  }
  .chat-avatar-circ {
    position: relative;
    z-index: 1;
    display: grid; place-items: center;
    width: 42px; height: 42px;
    border-radius: 999px;
    background: linear-gradient(135deg, #F6D9E1 0%, #D85475 100%);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.02em;
  }
  .chat-avatar-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    z-index: 2;
    display: grid; place-items: center;
    width: 18px; height: 18px;
    border-radius: 999px;
    background: #25D366;
    border: 2px solid #fff;
  }
  .chat-avatar-badge img {
    width: 10px; height: 10px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  /* Right side of header */
  .chat-actions { display: inline-flex; align-items: center; gap: 8px; }
  .pill-sm { padding: 4px 10px; font-size: 11px; }
  .chat-icon-btn {
    display: grid; place-items: center;
    width: 28px; height: 28px;
    border-radius: 999px;
    background: transparent;
    color: var(--fg-3);
    border: 1px solid transparent;
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out-expo), color var(--dur-fast) var(--ease-out-expo);
  }
  .chat-icon-btn:hover { background: var(--gc-n-100); color: var(--fg-2); }

  .chat-body {
    display: flex; flex-direction: column; gap: 14px;
    padding: 18px 4px 6px;
  }
  .msg {
    display: flex;
    gap: 8px;
    opacity: 0;
    animation: float-up 0.6s forwards var(--ease-out-expo);
  }
  .msg.recv { justify-content: flex-start; align-items: flex-end; }
  .msg.sent { justify-content: flex-end; align-items: flex-end; }
  .msg-col { display: flex; flex-direction: column; gap: 4px; min-width: 0; max-width: 88%; }
  .msg.recv .msg-col { align-items: flex-start; }
  .msg.sent .msg-col { align-items: flex-end; }

  /* Small avatar next to received bubbles */
  .msg-avatar {
    display: grid; place-items: center;
    width: 26px; height: 26px;
    border-radius: 999px;
    background: linear-gradient(135deg, #F6D9E1 0%, #D85475 100%);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    flex-shrink: 0;
    margin-bottom: 18px;
  }
  .msg.typing .msg-avatar { margin-bottom: 0; }

  /* Bubble polish (overrides global where useful) */
  .chat-frame .bubble {
    box-shadow: 0 1px 2px rgba(30, 25, 55, 0.06);
  }
  .chat-frame .bubble.sent {
    background: linear-gradient(135deg, var(--gc-primary) 0%, var(--gc-primary-dark) 100%);
    box-shadow: 0 4px 12px -4px rgba(89, 106, 213, 0.4);
  }

  .meta {
    font-size: 11px;
    color: var(--fg-3);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .meta-checks {
    width: 14px; height: 9px;
    color: var(--gc-primary);
  }

  /* Action card — replaces the plain green bubble */
  .action-card {
    position: relative;
    width: 100%;
    max-width: 320px;
    padding: 14px 14px 12px;
    border-radius: 14px 14px 4px 14px;
    background: linear-gradient(135deg, var(--gc-accent-green) 0%, var(--gc-accent-green-deep) 100%);
    color: #fff;
    box-shadow: 0 8px 20px -6px rgba(34, 119, 108, 0.42);
    overflow: hidden;
  }
  .action-card::before {
    content: '';
    position: absolute;
    top: -20px; right: -20px;
    width: 80px; height: 80px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    pointer-events: none;
  }
  .action-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .action-check {
    display: grid; place-items: center;
    width: 22px; height: 22px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
    flex-shrink: 0;
  }
  .action-check svg { width: 14px; height: 14px; }
  .action-strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14.5px;
    line-height: 1.3;
    letter-spacing: var(--tr-snug);
  }
  .action-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tool-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 8px 4px 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    font-size: 11.5px;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.01em;
  }
  .tool-chip svg {
    width: 12px;
    height: 12px;
    color: #fff;
    opacity: 0.9;
  }
  .tool-chip-ok {
    width: 10px !important;
    height: 10px !important;
    color: #BFEDE5 !important;
    opacity: 1 !important;
  }
  .typing-bubble { display: inline-flex; gap: 5px; padding: 12px 14px; }
  .typing-bubble span {
    width: 6px; height: 6px;
    border-radius: 999px;
