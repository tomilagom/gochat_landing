---
import SolutionPage from '../components/SolutionPage.astro';

const valueProps = [
  {
    title: '24/7 sales floor',
    blurb: 'Answers product, sizing and stock questions instantly, and turns visitors into orders while your team sleeps.',
  },
  {
    title: 'Cart recovery on autopilot',
    blurb: 'WhatsApp nudges that bring back abandoned checkouts with the right message at the right moment.',
  },
  {
    title: 'Personalised recommendations',
    blurb: 'Every conversation surfaces the products each shopper actually wants, the way a top salesperson would remember everyone.',
  },
  {
    title: 'Post-purchase made easy',
    blurb: 'Order tracking, returns and reorders handled inside the same chat. Fewer tickets, more loyalty.',
  },
