---
import SolutionPage from '../../components/SolutionPage.astro';

const valueProps = [
  {
    title: 'Atiende a cada comprador',
    blurb: 'Responde preguntas de precio, financiamiento y trade-in apenas alguien llega al sitio. Sin esperas ni formularios.',
  },
  {
    title: 'Agenda de test-drives',
    blurb: 'Reserva citas directamente en el calendario de la concesionaria con todo el contexto del comprador.',
  },
  {
    title: 'Matchmaker de inventario',
    blurb: 'Recomienda el modelo correcto desde tu stock en vivo según lo que cada comprador realmente necesita.',
  },
  {
    title: 'Service y seguimiento',
    blurb: 'Mantiene a los clientes en contacto después de la venta: recordatorios de service, recalls y reórdenes dentro del mismo chat.',
  },
];
---

<SolutionPage
  slug="automotive"
  lang="es"
  title="GoChat para Automotive · Un gemelo digital que vende como tu mejor vendedor"
  headlineBefore="Un gemelo digital que trabaja como tu mejor"
  highlight="vendedor"
  headlineAfter=""
  lead="Atrae compradores, responde preguntas, recupera carritos y personaliza cada experiencia en tiempo real, sin sumar presión a tu equipo."
  contextEyebrow="Por qué GoChat para automotive"
  contextTitle="Tu sitio web se ve impresionante. Pero no vende."
  contextBody="La mayoría de los sitios automotrices son catálogos lindos. GoChat los convierte en un piso de ventas activo: un gemelo digital de tu mejor vendedor, listo para hablar de inventario, financiamiento y test drives 24/7."
  valueProps={valueProps}
  video="/media/gochat-automotive.webm"
  contextImage="/media/automotive.png"
  contextImageAlt="Agente de IA guiando a un comprador a través del inventario de la concesionaria"
/>
