---
import AlternativePage from '../../components/AlternativePage.astro';

const ICONS = {
  speed:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>',
  price:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82Z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>',
  ai:     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6" width="16" height="14" rx="3"/><path d="M9 11h.01M15 11h.01M9 15c.8.7 1.8 1.2 3 1.2s2.2-.5 3-1.2"/><path d="M12 2v4M8 3l1.5 2M16 3l-1.5 2"/></svg>',
};

const highlights = [
  {
    icon: ICONS.speed,
    title: 'En vivo en semanas, no en trimestres',
    body: 'Los proyectos de Botmaker suelen convertirse en implementaciones de varios meses. GoChat lanza un agente de IA funcional en tu primer sprint, sin impuesto de servicios profesionales para empezar.',
  },
  {
    icon: ICONS.price,
    title: 'Precios transparentes y publicados',
    body: 'Sin laberintos de "solicita una cotización". GoChat publica los precios, incluye conversaciones ilimitadas y suma un equipo de crecimiento en Custom. Botmaker factura por sesión, por agente y por setup.',
  },
  {
    icon: ICONS.ai,
    title: 'IA moderna, no una NLU de caja negra',
    body: 'Conecta ChatGPT, Gemini o DeepSeek a agentes autónomos con herramientas y servidores MCP. La NLU propietaria de Botmaker es difícil de debuggear y más lenta para adaptarse a casos de uso nuevos.',
  },
];

const sections = [
  {
    title: 'Planes y precios',
    rows: [
      { label: 'Precios publicados en el sitio',               go: true,  rival: false },
      { label: 'Conversaciones ilimitadas',                     go: true,  rival: 'Por sesión' },
      { label: 'Sin servicios profesionales obligatorios',      go: true,  rival: false },
      { label: 'Migración white-glove incluida',                go: true,  rival: false },
    ],
  },
  {
    title: 'IA y agentes',
    rows: [
      { label: 'Trae tu propio modelo (ChatGPT, Gemini, DeepSeek)', go: true,  rival: 'NLU propietaria' },
      { label: 'Agentes autónomos de IA (multi-step + herramientas)', go: true,  rival: false },
      { label: 'Soporte para servidores MCP',                       go: true,  rival: false },
      { label: 'Funciones de IA y herramientas personalizadas',     go: true,  rival: 'Limitado' },
      { label: 'Resúmenes de conversación',                         go: true,  rival: true  },
    ],
  },
  {
    title: 'Canales',
    rows: [
      { label: 'WhatsApp Business API (BSP directo)',         go: true,  rival: true  },
      { label: 'Instagram + Messenger',                       go: true,  rival: true  },
      { label: 'TikTok',                                       go: true,  rival: false },
      { label: 'Widget de webchat',                           go: true,  rival: true  },
      { label: 'Telegram',                                    go: true,  rival: true  },
      { label: 'SMS',                                          go: true,  rival: true  },
    ],
  },
  {
    title: 'Constructor y operaciones',
    rows: [
      { label: 'Constructor de flujos drag-and-drop',         go: true,  rival: 'Basado en formularios' },
      { label: 'Flujos y sub-flujos ilimitados',               go: true,  rival: true  },
      { label: 'Setup de cuenta self-serve',                   go: true,  rival: false },
      { label: 'Derivación a chat en vivo con notas internas', go: true,  rival: true  },
      { label: 'Gestor de plantillas de WhatsApp',             go: true,  rival: true  },
      { label: 'Webhooks + API abierta',                       go: true,  rival: true  },
    ],
  },
  {
    title: 'Servicios de crecimiento',
    rows: [
      { label: 'Reuniones semanales de optimización',         go: true,  rival: false },
      { label: 'Plataforma de Datos de Cliente (Customer.io)', go: true,  rival: false },
      { label: 'Notificaciones push e in-app',                 go: true,  rival: false },
      { label: 'Expertos de crecimiento de Hyppo en tu cuenta', go: true,  rival: false },
    ],
  },
];

const switchSteps = [
  {
    title: 'Exporta tus activos de Botmaker',
    body: 'Extraemos las definiciones del bot, los intents de entrenamiento y las plantillas de WhatsApp para que nada se reconstruya desde cero y nada se pierda en el camino.',
  },
  {
    title: 'Reconstruye sobre agentes de IA modernos',
    body: 'Los expertos de Hyppo traducen cada intent en un agente de GoChat con el modelo que elijas. Espera un salto de calidad: menos fallbacks, menos callejones sin salida.',
  },
  {
    title: 'Migra WhatsApp y corre en doble vía',
    body: 'Coordinamos la migración de BSP con Meta y corremos ambos bots en paralelo hasta que las métricas de performance sean iguales o mejores. Ahí sí, hacemos el switch.',
  },
];

const faqs = [
  {
    q: '¿Cómo se compara el precio de GoChat con el de Botmaker?',
    a: 'Botmaker factura por sesión y agrega servicios profesionales a la mayoría de los proyectos. GoChat publica precios planos con conversaciones ilimitadas incluidas, más un pod de crecimiento en los planes Custom.',
  },
  {
    q: '¿Puedo mantener mi número de WhatsApp?',
    a: 'Sí. GoChat es BSP directo de WhatsApp, así que gestionamos la migración de tu número actual con Meta. Tus clientes no ven ningún cambio.',
  },
  {
    q: '¿Cómo se compara la IA de GoChat con la NLU de Botmaker?',
    a: 'Botmaker usa una NLU propietaria que entrenas con intents y entidades. GoChat usa el LLM frontier que elijas (ChatGPT, Gemini, DeepSeek) envuelto en agentes autónomos con herramientas. Vas a tener mayor precisión de entrada y una iteración mucho más rápida.',
  },
  {
    q: '¿GoChat es enterprise-ready como Botmaker?',
    a: 'Sí. GoChat viene con SOC 2 Type II, ISO 27001, permisos basados en roles y SSO. Hyppo también lleva la parte operativa: reviews semanales, dashboards y optimización continua de flujos.',
  },
  {
    q: '¿Cuánto demora la migración?',
    a: 'Las migraciones estándar de Botmaker se completan en 3-5 semanas según la cantidad de bots e integraciones. Las migraciones enterprise complejas con CRMs y sistemas back-office demoran 6-8 semanas.',
  },
];
---

<AlternativePage
  lang="es"
  competitor="Botmaker"
  competitorTagline="Botmaker construyó bots sólidos para la era de WhatsApp. Pero su NLU propietaria, precios opacos y ciclos de implementación pesados hacen que escalar sea lento. GoChat lo reemplaza con agentes de IA modernos, planes transparentes y un pod de crecimiento que entrega valor cada semana."
  pageTitle="GoChat · La alternativa a Botmaker para equipos AI-first"
  pageDescription="¿Buscas una alternativa a Botmaker? Compara GoChat lado a lado: agentes autónomos de IA, precios transparentes, sin impuesto de servicios profesionales y un equipo de crecimiento incluido."
  headlineBefore="La"
  highlight="alternativa a Botmaker"
  headlineAfter="que eligen los equipos AI-first"
  lead="Si ya te cansaste de cotizaciones opacas, NLUs propietarias y trimestres enteros de implementación, GoChat es el upgrade: agentes de IA modernos, precios planos y un pod de crecimiento de Hyppo que entrega cada semana."
  highlights={highlights}
  sections={sections}
  switchTitle="Migra desde Botmaker sin reconstruir todo"
  switchSteps={switchSteps}
  faqs={faqs}
/>
