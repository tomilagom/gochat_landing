---
import SolutionPage from '../../components/SolutionPage.astro';

const valueProps = [
  {
    title: 'Calificación instantánea de leads',
    blurb: 'Presupuesto, ubicación, timing e intención capturados en los primeros mensajes — para que tus agentes solo llamen a los leads que valen la pena.',
  },
  {
    title: 'Visitas agendadas 24/7',
    blurb: 'Visitas reservadas directo en los calendarios de tus agentes, incluso a las 2am — sin más fines de semana perdidos ni consultas sin respuesta.',
  },
  {
    title: 'Matchmaker de propiedades',
    blurb: 'Sugiere las propiedades correctas de tu portafolio según lo que cada comprador realmente busca, no lo que escribió.',
  },
  {
    title: 'Concierge multilingüe',
    blurb: 'Habla con compradores internacionales en su propio idioma y mantiene la conversación cálida hasta que tu equipo intervenga.',
  },
];
---

<SolutionPage
  slug="real-estate"
  lang="es"
  title="GoChat para Real Estate — Un gemelo digital que trabaja como tu mejor concierge"
  headlineBefore="Un gemelo digital que trabaja como tu mejor"
  highlight="concierge"
  headlineAfter=""
  lead="Construido para real estate: atrae, califica y convierte compradores y vendedores — de forma automática, 24/7, con una experiencia humana que tus clientes van a amar."
  contextEyebrow="Por qué GoChat para real estate"
  contextTitle="Los listings no venden propiedades. Las conversaciones, sí."
  contextBody="La mayoría de los sitios inmobiliarios solo muestran fotos y esperan. GoChat convierte cada visita en una conversación guiada — calificando intención, agendando visitas y respondiendo las preguntas difíciles, incluso fuera del horario de oficina."
  valueProps={valueProps}
  video="/media/gochat-real-estate.webm"
  contextImage="/media/real-estate-e1763391592382.png"
  contextImageAlt="Una casa moderna — el tipo de propiedad para la que tu concierge de IA ayuda a los clientes a agendar una visita"
/>
