---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import BrandLogos from '../../components/BrandLogos.astro';
import Industries from '../../components/Industries.astro';
import ChannelCapabilities from '../../components/ChannelCapabilities.astro';
import PlatformShowcase from '../../components/PlatformShowcase.astro';
import Capabilities from '../../components/Capabilities.astro';
import BoostSales from '../../components/BoostSales.astro';
import ScaleSupport from '../../components/ScaleSupport.astro';
import Integrations from '../../components/Integrations.astro';
import Pricing from '../../components/Pricing.astro';
import Comparison from '../../components/Comparison.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQs from '../../components/FAQs.astro';
import BookDemo from '../../components/BookDemo.astro';
import Footer from '../../components/Footer.astro';
import { organizationSchema, websiteSchema, softwareApplicationSchema, homepageFaqsSchema } from '../../lib/seo';

const jsonLd = [
  organizationSchema(),
  websiteSchema('es'),
  softwareApplicationSchema('es'),
  homepageFaqsSchema('es'),
];
---

<Layout
  lang="es"
  title="GoChat · El chatbot de IA para cualquier negocio"
  description="Construye flujos de automatización en minutos sobre 12+ canales sociales. Aumenta tus ingresos, reduce los costos operativos y enamora a tus clientes."
  jsonLd={jsonLd}
>
  <Nav lang="es" />
  <main>
    <Hero lang="es" />
    <BrandLogos lang="es" />
    <Industries lang="es" />
    <ChannelCapabilities lang="es" />
    <PlatformShowcase lang="es" />
    <Capabilities lang="es" />
    <BoostSales lang="es" />
    <ScaleSupport lang="es" />
    <Integrations lang="es" />
    <Pricing lang="es" />
    <Comparison lang="es" />
    <Testimonials lang="es" />
    <FAQs lang="es" />
    <BookDemo lang="es" />
  </main>
  <Footer lang="es" />
</Layout>
