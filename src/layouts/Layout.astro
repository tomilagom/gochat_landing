---
import '../styles/global.css';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
import { SITE_URL, absoluteUrl, type Lang } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'GoChat · The AI Chatbot for any business',
  description = 'Build automation flows in minutes over 12+ social channels. Increase your revenue, reduce operation costs and delight your customers.',
  lang = 'en',
  ogImage = '/media/gochat_AI_capabilities-scaled.png',
  jsonLd,
} = Astro.props;

const pathname = Astro.url.pathname;
const canonicalUrl = absoluteUrl(pathname, lang);
const enAlternate = absoluteUrl(pathname, 'en');
const esAlternate = absoluteUrl(pathname, 'es');
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`;
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
const ogLocaleAlt = lang === 'es' ? 'en_US' : 'es_ES';

const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/media/cropped-gochat_logo-32x32.png" />
    <link rel="apple-touch-icon" href="/media/cropped-gochat_logo-180x180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enAlternate} />
    <link rel="alternate" hreflang="es" href={esAlternate} />
    <link rel="alternate" hreflang="x-default" href={enAlternate} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GoChat" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#FFFFFF" />
    <meta name="robots" content="index,follow" />

    {jsonLdItems.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5K5V8QKD5Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-5K5V8QKD5Y');
    </script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <slot />
    <WhatsAppWidget lang={lang} />
    <script>
      // Reveal-on-scroll — supports plain .reveal and .reveal-stagger
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      );
      document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => io.observe(el));

      // Stat counter — counts a number up to its target when visible
      const fmt = (n: number, fmtStr: string) => {
        if (fmtStr.includes('k')) return '+' + Math.round(n) + 'k';
        if (fmtStr.includes('%')) return n.toFixed(2) + '%';
        return n.toLocaleString();
      };
      const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
      const counter = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          const el = e.target as HTMLElement;
          const target = parseFloat(el.dataset.count || '0');
          const format = el.dataset.format || '';
          const dur = 1400;
          const start = performance.now();
          function step(now: number) {
            const t = Math.min(1, (now - start) / dur);
            el.textContent = fmt(target * easeOutCubic(t), format);
            if (t < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
          counter.unobserve(el);
        }
      }, { threshold: 0.5 });
      document.querySelectorAll('[data-count]').forEach((el) => counter.observe(el));

      // Scroll progress bar
      const progress = document.querySelector<HTMLElement>('.scroll-progress');
      if (progress) {
        const onScroll = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
          progress.style.setProperty('--p', pct.toFixed(2) + '%');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Parallax on decorative blobs
      const blobs = document.querySelectorAll<HTMLElement>('.parallax');
      if (blobs.length) {
        const onScrollPx = () => {
          const y = window.scrollY * 0.08;
          blobs.forEach((b) => b.style.setProperty('--y', `${y}px`));
        };
        window.addEventListener('scroll', onScrollPx, { passive: true });
      }

      // Magnetic hover on primary CTAs
      document.querySelectorAll<HTMLElement>('.magnetic').forEach((el) => {
        el.addEventListener('mousemove', (e) => {
          const r = el.getBoundingClientRect();
          const x = (e.clientX - r.left - r.width / 2) * 0.18;
          const y = (e.clientY - r.top - r.height / 2) * 0.25;
          el.style.transform = `translate(${x}px, ${y}px)`;
        });
        el.addEventListener('mouseleave', () => {
          el.style.transform = '';
        });
      });
    </script>

    <!-- Browser language detection + redirect (runs before paint when possible) -->
    <script is:inline>
      (function () {
        var supportedLanguages = { es: '/es' };
        var cookieName = 'gochat_lang_redirected';
        var cookieDays = 30;

        function setCookie(name, value, days) {
          var d = new Date();
          d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
          document.cookie = name + '=' + (value || '') + '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
        }
        function getCookie(name) {
          var eq = name + '=';
          var parts = document.cookie.split(';');
          for (var i = 0; i < parts.length; i++) {
            var c = parts[i];
            while (c.charAt(0) === ' ') c = c.substring(1);
            if (c.indexOf(eq) === 0) return c.substring(eq.length);
          }
          return null;
        }

        if (getCookie(cookieName)) return;

        var path = window.location.pathname;

        // Already on a localized path — don't redirect.
        if (path.indexOf('/es/') === 0 || path === '/es') {
          setCookie(cookieName, '1', cookieDays);
          return;
        }

        var browserLang = (navigator.language || navigator.userLanguage || 'en').toLowerCase();
        var base = browserLang.split('-')[0];
        var prefix = supportedLanguages[base];

        if (prefix) {
          var target = path === '/' ? prefix + '/' : prefix + path;
          setCookie(cookieName, '1', cookieDays);
          window.location.replace(target + window.location.search + window.location.hash);
        } else {
          setCookie(cookieName, '1', cookieDays);
        }
      })();
    </script>
  </body>
</html>
